# Шаблон для production окружения
# На сервере: cp backend/.env.prod.example backend/.env
# НИКОГДА не коммить backend/.env

DB_URL=jdbc:postgresql://postgres:5432/recipebook
DB_USERNAME=recipebook
DB_PASSWORD=<strong-password>

# JWT — минимум 256 бит: openssl rand -base64 64
JWT_SECRET=<min-256-bit-secret>

# MinIO — сервис внутри Docker сети (порты не открыты наружу)
# Console доступна через SSH tunnel: ssh -L 9001:localhost:9001 deploy@147.45.153.120
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<strong-access-key>
MINIO_SECRET_KEY=<strong-secret-key>
# Публичный URL для presigned ссылок (что видит браузер)
MINIO_PUBLIC_URL=https://darink.ru

# Admin — создаётся автоматически при первом старте
ADMIN_EMAIL=admin@recipebook.com
ADMIN_PASSWORD=<strong-password>
ADMIN_USERNAME=admin
